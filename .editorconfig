# Type: EditorConfig settings
# Function: Unify line endings, indentation, encoding, etc.

# Default rules for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

# Markdown exception: Allow trailing whitespace (to prevent truncating block lines)
[*.md]
trim_trailing_whitespace = false

# VHDL / Verilog can use 2 or 4 spaces; this is the 2-space version
[*.vhd]
indent_size = 2

[*.vhdl]
indent_size = 2

[*.v]
indent_size = 2

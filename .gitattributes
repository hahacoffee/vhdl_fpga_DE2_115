# Line endings: normalize text files to LF to avoid cross-platform churn.
* text=auto eol=lf

*.vhdl text eol=lf
*.vhd  text eol=lf
*.v    text eol=lf
*.qsf  text eol=lf
*.qpf  text eol=lf
*.bdf  text eol=lf
*.vwf  text eol=lf
*.tcl  text eol=lf
*.md   text eol=lf
*.hex  text eol=lf

# Binary assets (documentation screenshots).
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.bmp  binary
